{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "email": {
      "type": "string",
      "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
    },
    "comment": {
      "type": "string",
      "minLength": 1
    },
    "post_id": {
      "type": "integer"
    }
  },
  "required": ["name", "email", "comment", "post_id"],
  "additionalProperties": true
}
